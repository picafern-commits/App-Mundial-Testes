rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // v174 — Push/firestore total: tokens, preferências e testes push.
    match /notificationTokens/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /notificationTests/{docId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    match /notificationPreferences/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /pushPreferences/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /pushTokens/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /deviceTokens/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    // Mantém o comportamento geral da app para users autenticados.
    match /{document=**} {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
