rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function chatAdminEmail() {
      return signedIn() && request.auth.token.email in ["pica.fern@gmail.com"];
    }

    function chatAdminUser() {
      return chatAdminEmail() || (
        signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == "admin"
          || get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.permissions.editResults == true
        )
      );
    }

    match /games/{gameId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /bets/{betId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }



    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /presence/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }


    match /chatMessages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 0
        && request.resource.data.text.size() <= 500;
      allow update: if signedIn();
      allow delete: if signedIn() && (
        resource.data.uid == request.auth.uid ||
        chatAdminUser()
      );
    }

    match /chatAdminMessages/{messageId} {
      allow read: if chatAdminUser();
      allow create: if chatAdminUser()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 0
        && request.resource.data.text.size() <= 500;
      allow update: if chatAdminUser();
      allow delete: if chatAdminUser();
    }

    match /chatSettings/{settingId} {
      allow read: if signedIn();
      allow create, update, delete: if chatAdminUser();
    }

    match /chatTyping/{typingId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /notificationTokens/{tokenId} {
      allow read: if chatAdminUser() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /notificationTests/{testId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /appSettings/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
