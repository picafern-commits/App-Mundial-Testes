rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // v175 — coleções de push abertas para destravar ativação de dispositivos.
    // Só afeta tokens/preferências/testes push.
    match /notificationTokens/{docId} {
      allow read, create, update, delete: if true;
    }

    match /notificationTests/{docId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    match /notificationPreferences/{docId} {
      allow read, create, update, delete: if true;
    }

    match /pushPreferences/{docId} {
      allow read, create, update, delete: if true;
    }

    match /pushTokens/{docId} {
      allow read, create, update, delete: if true;
    }

    match /deviceTokens/{docId} {
      allow read, create, update, delete: if true;
    }

    // Resto da app mantém igual: leitura pública e escrita só com login.
    match /{document=**} {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
